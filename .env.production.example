# Frontend build-time token used by Vite during Docker image build.
# Use a real production JWT that matches backend validation settings.
VITE_DEMO_JWT=replace-with-production-jwt

# Public DNS name pointing to this server (required for automatic Let's Encrypt certs).
TLS_DOMAIN=slots.example.com

# Email used for ACME (Let's Encrypt) account registration.
ACME_EMAIL=ops@example.com

# --- Sentry (leave blank to disable) ---
# Backend (Node/Express) DSN — create an Express project in sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (React) DSN — baked in at Vite build time
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR=1.0
