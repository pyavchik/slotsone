{
  "name": "slotsone-appium",
  "version": "1.0.0",
  "private": true,
  "description": "Appium mobile test automation for SlotsOne",
  "scripts": {
    "test:android": "wdio run wdio.android.conf.ts",
    "test:ios": "wdio run wdio.ios.conf.ts",
    "test:browserstack": "wdio run wdio.browserstack.conf.ts",
    "test:android:smoke": "wdio run wdio.android.conf.ts --spec tests/smoke/",
    "test:ios:smoke": "wdio run wdio.ios.conf.ts --spec tests/smoke/",
    "report:generate": "allure generate allure-results --clean -o reports/allure-html",
    "report:open": "allure open reports/allure-html"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.6.4",
    "@wdio/appium-service": "^9.6.4",
    "@wdio/browserstack-service": "^9.6.4",
    "@wdio/cli": "^9.6.4",
    "@wdio/local-runner": "^9.6.4",
    "@wdio/mocha-framework": "^9.6.4",
    "@wdio/spec-reporter": "^9.6.4",
    "@wdio/types": "^9.6.4",
    "allure-commandline": "^2.32.0",
    "appium": "^2.17.1",
    "appium-uiautomator2-driver": "^3.8.0",
    "appium-xcuitest-driver": "^7.33.0",
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
