<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SlotsOne Headless Suite (API + BDD, no browser)" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="com.slotsone.qa.api.AuthApiTest"/>
            <class name="com.slotsone.qa.api.SpinApiTest"/>
            <class name="com.slotsone.qa.api.HistoryApiTest"/>
        </classes>
    </test>

    <test name="BDD API Scenarios">
        <classes>
            <class name="com.slotsone.qa.bdd.CucumberApiRunner"/>
        </classes>
    </test>
</suite>
